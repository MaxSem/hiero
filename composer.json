{
    "name": "maxsem/hiero",
    "description": "Egyptian hieroglyphic text to SVG renderer",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MaxSem\\Hiero\\": "src/"
        }
    },
    "autoload-dev" : {
        "psr-4": {
          "Tests\\Hiero\\" : "./tests"}
    },
    "authors": [
        {
            "name": "Max Semenik",
            "email": "maxsem.wiki@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "symfony/polyfill-php85": "^1.37",
        "symfony/process": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "slevomat/coding-standard": "^8.28",
        "ext-imagick": "*"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
